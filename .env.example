# RKE — Recursive Knowledge Engine — environment variables
# Copy to .env and customize. RKE_* variables override values in config/rke.yaml.
# .env is gitignored and never committed.

# ── Wiki ──────────────────────────────────────────────────
# RKE_WIKI_PATH=data/wiki

# ── Qdrant (vector store) ─────────────────────────────────
# RKE_QDRANT_HOST=localhost
# RKE_QDRANT_PORT=6333
# RKE_QDRANT_GRPC_PORT=6334
# RKE_QDRANT_COLLECTION=rke_main
# RKE_QDRANT_API_KEY=                 # only set if using Qdrant Cloud

# ── FalkorDB (knowledge graph) ────────────────────────────
# RKE_FALKORDB_HOST=localhost
# RKE_FALKORDB_PORT=6379
# RKE_FALKORDB_GRAPH=rke
# RKE_FALKORDB_PASSWORD=              # only set if your instance requires auth

# ── Embeddings ────────────────────────────────────────────
# RKE_EMBEDDING_MODEL=BAAI/bge-m3
# RKE_EMBEDDING_DEVICE=cpu            # cuda:0 / cuda / cpu / mps
# RKE_EMBEDDING_DIMENSIONS=1024

# ── RLM Router (optional, for sub_rlm() LLM calls) ────────
# RKE_LLM_PROVIDER=                   # anthropic | openai | gemini | none
# RKE_LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── Google Drive ingestion (optional) ─────────────────────
# Path to OAuth client_secret.json downloaded from GCP console.
# The token cache file is also gitignored.
# RKE_DRIVE_CLIENT_SECRETS=credentials.json
# RKE_DRIVE_TOKEN_CACHE=google_token.json

# ── Logging ───────────────────────────────────────────────
# RKE_LOG_LEVEL=INFO
