# Knowledge source definitions.
# Copy to config/sources.yaml and customize. config/sources.yaml is gitignored.
#
# Each entry describes a source the ingestion pipeline can pull from.
# Supported types: paths (local files/dirs), git (local or remote git repos),
# drive (Google Drive folder).

sources:
  example-project:
    name: "Example Project Docs"
    type: paths
    paths:
      - "./README.md"
      - "./docs"
    category: "projects/example"
    tags: ["project", "docs"]

  example-research:
    name: "Research Notes"
    type: paths
    paths:
      - "./notes"
    category: "entities"
    tags: ["research"]

  # example-git-repo:
